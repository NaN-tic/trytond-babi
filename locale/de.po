msgctxt "model:ir.message,text:msg_table_failed"
msgid "Computation of \"%(table)s\" failed."
msgstr "Die Berechnung von „%(table)s“ ist fehlgeschlagen."

msgctxt "model:ir.message,text:msg_table_internal_name_unique"
msgid "Table's internal name must be unique."
msgstr "Der interne Name der Tabelle muss eindeutig sein."

msgctxt "model:ir.message,text:msg_table_limit"
msgid "(limited to %(number)s)"
msgstr "(begrenzt auf %(number)s)"

msgctxt "model:ir.message,text:msg_table_no_fields"
msgid "Table \"%(table)s\" cannot be computed because it has no fields."
msgstr "Die Tabelle „%(table)s“ kann nicht berechnet werden, da sie keine Felder enthält."

msgctxt "model:ir.message,text:msg_table_rows"
msgid "%(count)s rows"
msgstr "%(count)s Zeilen"

msgctxt "model:ir.message,text:msg_table_successful"
msgid "Computation of \"%(table)s\" finished successfully."
msgstr "Die Berechnung von „%(table)s“ wurde erfolgreich abgeschlossen."

msgctxt "model:ir.message,text:msg_tables_filename"
msgid "tables"
msgstr "Tische"

msgctxt "model:ir.message,text:msg_tables_not_created"
msgid "Warning: tables could not be created. Please check your query."
msgstr "Warnung: Tabellen konnten nicht erstellt werden. Bitte überprüfen Sie Ihre Anfrage."

msgctxt "model:ir.message,text:msg_too_many_parameters"
msgid ""
"There can not be more than \"%(max)s\" parameters of type \"%(type)s\" in "
"\"%(widget)s\"."
msgstr "Es dürfen nicht mehr als „%(max)s“ Parameter vom Typ „%(type)s“ in „%(widget)s“ vorhanden sein."

msgctxt "model:ir.message,text:msg_waiting_for_computation"
msgid "Waiting for computation of table to finish."
msgstr "Warten auf den Abschluss der Tabellenberechnung."

msgctxt "model:ir.message,text:msg_widget_help"
msgid ""
"The following is the list of valid parameter types wth the number of minimum and maximum occurrences allowed:\n"
"\n"
"%(list)s"
msgstr ""
"Im Folgenden finden Sie die Liste der gültigen Parametertypen mit der Anzahl der zulässigen minimalen und maximalen Vorkommen:\n"
"\n"
"%(list)s"

msgctxt "model:ir.message,text:msg_wrong_info"
msgid ""
"The information returned from the field %(field)s is not correct or you don't have enough permissions to access it.             Records found by query: %(query_count)s\n"
"            Records found by Model: %(model_query_count)s\n"
"            "
msgstr ""
"Die vom Feld %(field)s zurückgegebenen Informationen sind nicht korrekt oder Sie verfügen nicht über ausreichende Berechtigungen, um darauf zuzugreifen.             Von der Abfrage gefundene Datensätze: %(query_count)s\n"
"            Vom Modell gefundene Datensätze: %(model_query_count)s\n"
"            "

msgctxt "model:ir.message,text:msg_yes"
msgid "Yes"
msgstr "Ja"

msgctxt "model:ir.message,text:no_dimensions"
msgid "Report \"%(report)s\" has no dimensions. At least one is needed."
msgstr "Bericht „%(report)s“ hat keine Dimensionen. Mindestens einer wird benötigt."

msgctxt "model:ir.message,text:no_execution"
msgid ""
"No execution found for current record. Execute the update data wizard in "
"order to create one."
msgstr "Für den aktuellen Datensatz wurde keine Ausführung gefunden. Führen Sie den Datenaktualisierungsassistenten aus, um einen zu erstellen."

msgctxt "model:ir.message,text:no_measures"
msgid "Report \"%(report)s\" has no measures. At least one is needed."
msgstr "Bericht „%(report)s“ hat keine Kennzahlen. Mindestens einer wird benötigt."

msgctxt "model:ir.message,text:no_menus"
msgid ""
"No menus found for report %(report)s. In order to view its data you must "
"create menu entries."
msgstr "Für den Bericht %(report)s wurden keine Menüs gefunden. Um die Daten anzuzeigen, müssen Sie Menüeinträge erstellen."

msgctxt "model:ir.message,text:no_report"
msgid "No report found for current execution"
msgstr "Keine Bericht für aktuelle Ausführung gefunden"

msgctxt "model:ir.message,text:one_measure_in_pie_charts"
msgid "Only one measure can be used in pie charts"
msgstr "Nur eine Messgrösse kann in Kuchendiagrammen verwendet werden."

msgctxt "model:ir.message,text:parameter_not_found"
msgid ""
"Parameter \"%(parameter)s\" not found in Domain nor in Python Expression of "
"filter \"%(filter)s\"."
msgstr "Der Parameter „%(parameter)s“ ​​wurde weder in der Domäne noch im Python-Ausdruck des Filters „%(filter)s“ ​​gefunden."

msgctxt "model:ir.message,text:report_modification_warning"
msgid ""
"Report \"%(report)s\" will be renamed, but if you want to also rename the "
"menus you should create the menus again. Are you sure you want to continue "
"with this action?"
msgstr "Der Bericht „%(report)s“ wird umbenannt. Wenn Sie jedoch auch die Menüs umbenennen möchten, sollten Sie die Menüs erneut erstellen. Sind Sie sicher, dass Sie mit dieser Aktion fortfahren möchten?"

msgctxt "model:ir.message,text:report_not_exists"
msgid ""
"Report \"%(report)s\" no longer exists or you do not have the rights to "
"access it."
msgstr "Der Bericht „%(report)s“ existiert nicht mehr oder Sie haben nicht die Rechte, darauf zuzugreifen."

msgctxt "model:ir.message,text:timeout_exception"
msgid ""
"Report \"%(report)s\" will be renamed, but if you want to also rename the "
"menus you should create the menus again. Are you sure you want to continue "
"with this action?"
msgstr "Der Bericht „%(report)s“ wird umbenannt. Wenn Sie jedoch auch die Menüs umbenennen möchten, sollten Sie die Menüs erneut erstellen. Sind Sie sicher, dass Sie mit dieser Aktion fortfahren möchten?"

